#!/usr/bin/env bash
# Spellguard setup skill entry point.
set -euo pipefail
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BUNDLE="${PLUGIN_ROOT}/dist/bin/run-spellguard-setup.mjs"
if [[ ! -f "$BUNDLE" ]]; then
  echo '[spellguard] dist/ missing — run `pnpm --filter @spellguard/claude-code-plugin build`' >&2
  exit 1
fi
NODE_BIN="$(bash "${PLUGIN_ROOT}/bin/resolve-node" 2>/dev/null || true)"
if [[ -z "$NODE_BIN" ]]; then
  echo '[spellguard] node executable not found; cannot run setup.' >&2
  exit 1
fi
exec "$NODE_BIN" "$BUNDLE" "$@"
