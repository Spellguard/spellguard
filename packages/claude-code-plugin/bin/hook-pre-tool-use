#!/usr/bin/env bash
# PreToolUse hook wrapper.
set -euo pipefail
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BUNDLE="${PLUGIN_ROOT}/dist/bin/run-pre-tool-use.mjs"
if [[ ! -f "$BUNDLE" ]]; then
  printf '{"continue":true}\n'
  exit 0
fi
NODE_BIN="$(bash "${PLUGIN_ROOT}/bin/resolve-node" 2>/dev/null || true)"
if [[ -z "$NODE_BIN" ]]; then
  echo '[spellguard] node executable not found; allowing tool call without Spellguard scan.' >&2
  printf '{"continue":true}\n'
  exit 0
fi
exec "$NODE_BIN" "$BUNDLE"
