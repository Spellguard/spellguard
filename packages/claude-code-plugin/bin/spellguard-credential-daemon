#!/usr/bin/env bash
# spellguard-credential-daemon — npm-installed CLI entry point for the
# managed Claude Code credential daemon (the supervised "portless" online
# process). Declared in `package.json#bin` so
# `npm install -g @spellguard/claude-code-plugin` puts a
# `spellguard-credential-daemon` binary on PATH; the managed boot script's
# systemd unit ExecStart's it (FIND-DA9: the boot script invokes this command
# but the package previously exposed only `spellguard-setup`).
set -euo pipefail

# Resolve PLUGIN_ROOT regardless of where the bin symlink lives (npm global
# installs symlink /usr/lib/node_modules/.bin/spellguard-credential-daemon here;
# readlink -f follows the chain).
SCRIPT_PATH="$(readlink -f "$0" 2>/dev/null || python3 -c 'import os,sys; print(os.path.realpath(sys.argv[1]))' "$0")"
PLUGIN_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"

BUNDLE="${PLUGIN_ROOT}/dist/bin/spellguard-credential-daemon.mjs"
if [[ ! -f "$BUNDLE" ]]; then
  echo '[spellguard] dist/ missing — run `pnpm --filter @spellguard/claude-code-plugin build`' >&2
  exit 1
fi
NODE_BIN="$(bash "${PLUGIN_ROOT}/bin/resolve-node" 2>/dev/null || true)"
if [[ -z "$NODE_BIN" ]]; then
  echo '[spellguard] node executable not found; cannot run the credential daemon.' >&2
  exit 1
fi
exec "$NODE_BIN" "$BUNDLE" "$@"
