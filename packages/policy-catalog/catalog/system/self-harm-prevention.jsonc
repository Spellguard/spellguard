          "\\b(?:replace\\s+my\\s+(?:psychiatrist|therapist)|professional\\s+(?:psychiatric|mental\\s+health)\\s+(?:treatment|therapy)|treatment\\s+plan\\s+for\\s+my\\s+depression|recommend\\s+a\\s+specific\\s+treatment\\s+approach)\\b",
          "\\b(?:change\\s+my\\s+dosage|start\\s+medication\\s+for\\s+my\\s+anxiety|suggest\\s+medic(?:ation|ines?)\\s+to\\s+treat\\s+my\\s+depression|stop\\s+my\\s+prescribed(?:\\s+anti-?psychotic)?\\s+medication)\\b",
