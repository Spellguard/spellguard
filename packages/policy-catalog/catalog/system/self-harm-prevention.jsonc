{
  // Self-harm prevention policy — uses BuiltinEngine with policyType: 'self-harm-prevention'.
  // Config shape: includeCrisisResources, customCrisisMessage
  "policies": [
    {
      "slug": "self-harm-prevention-baseline",
      "name": "Self-Harm and Crisis Prevention",
      "description": "Detects crisis and self-harm content in two tiers: critical immediate danger patterns and concerning but less immediate patterns. Provides crisis resources (988 Lifeline, Crisis Text Line, IASP) by default",
