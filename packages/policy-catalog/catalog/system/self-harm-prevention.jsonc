      "level": "system",
      "severity": "high",
      "failBehavior": "block",
      "config": {
        "includeCrisisResources": true,
        "customPatterns": [
          "\\b(anorexi\\w*|bulimi\\w*|starv\\w*\\s+(?:my|your)self|purging|binge\\s+eat|eating\\s+disorder)\\b",
          "\\b(?:how\\s+(?:to|do\\s+I|can\\s+I))\\s+(?:cut|burn|hurt|injure|harm|poison|hang|drown|shoot|stab)\\s+(?:my|your)self\\b",
          "\\b(?:can\\s+you|please)\\s+(?:prescribe|diagnose|give\\s+me\\s+(?:a\\s+)?(?:prescription|medication|dosage))\\b",
