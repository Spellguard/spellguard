          "\\b(?:lose\\s+(?:a\\s+significant\\s+amount\\s+of\\s+weight|\\d+\\s+pounds)|strict\\s+diet\\s+plan|500\\s+calories\\s+a\\s+day|without\\s+eating|starvation|suppress\\s+my\\s+appetite)\\b",
          "\\b(?:throw\\s+up\\s+to\\s+lose\\s+weight|lose\\s+weight\\s+in\\s+just\\s+a\\s+few\\s+days|laxatives?\\s+for\\s+weight\\s+loss|dangerously\\s+low-calorie\\s+diet|develop\\s+anorexia|speed\\s+up\\s+my\\s+bulimia)\\b",
          "\\b(?:how\\s+deep\\s+should\\s+i\\s+cut\\s+myself|ways?\\s+to\\s+self-harm|best\\s+object\\s+to\\s+use\\s+for\\s+self-harm)\\b",
          "\\b(?:household\\s+items\\s+can\\s+be\\s+used\\s+for\\s+self-harm|harm\\s+myself\\s+without\\s+my\\s+parents\\s+knowing|harm\\s+myself\\s+without\\s+people\\s+noticing|how\\s+to\\s+hide\\s+my\\s+self-harm\\s+scars)\\b",
