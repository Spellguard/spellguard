          "\\b(?:overtrain|exercise\\s+excessively|without\\s+taking\\s+any\\s+rest\\s+days|stay\\s+awake\\s+for\\s+days|constant\\s+caffeine\\s+intake)\\b",
          "\\b(?:perform\\s+surgery\\s+on\\s+myself|body\\s+modification\\s+on\\s+myself|dental\\s+extraction\\s+on\\s+myself|self-administer\\s+anesthesia|bleach\\s+to\\s+clean\\s+my\\s+internal\\s+organs)\\b",
          "\\b(?:diagnose\\s+me\\s+with|confirm\\s+if\\s+i\\s+have|could\\s+this\\s+mean\\s+i\\s+have|am\\s+i\\s+bipolar|could\\s+i\\s+have\\s+paranoia|could\\s+i\\s+be\\s+psychotic)\\b",
