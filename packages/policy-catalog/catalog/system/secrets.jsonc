{
  // Secret/credential detection policy — uses BuiltinEngine with policyType: 'secrets'.
  // Config shape: categories, customPatterns, label
  "policies": [
    {
      "slug": "secrets-baseline",
      "name": "Secret and Credential Detection",
      "description": "Detects leaked secrets and credentials including AWS keys, GitHub tokens, OpenAI/Anthropic API keys, Stripe keys, private keys, JWTs, Slack/Discord tokens, and generic API keys or passwords",
      "type": "secrets",
      "level": "system",
      "severity": "critical",
      "failBehavior": "block",
      "config": {
        "categories": [
          "aws",
          "github",
          "openai",
          "anthropic",
          "stripe",
          "privateKey",
          "jwt",
          "slack",
          "discord",
          "genericApiKey",
          "genericSecret"
        ],
        "customPatterns": [
          "\\bsk-[A-Za-z0-9]{20,}\\b",
          "\\b(password|passwd|pwd)\\s+\\w+\\s+\\S{8,}",
          "\\b\\d{4}[-\\s]?\\d{4}[-\\s]?\\d{4}[-\\s]?\\d{4}\\b",
          "\\b\\d{3}-\\d{2}-\\d{4}\\b"
        ],
        "label": "secrets"
      },
      "defaultBinding": {
        "direction": "both",
        "effect": "block",
        "priority": 100
      },
      "provenance": {
        "source": "extracted:builtin-engine",
        "dateAdded": "2026-03-09",
        "reference": "packages/verifier/src/proxy/builtin-engine.ts:checkSecrets"
      }
    }
  ]
}
