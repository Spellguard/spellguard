#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${NODE_BINARY:-}" && -x "${NODE_BINARY}" ]]; then
  printf '%s\n' "${NODE_BINARY}"
  exit 0
fi

if command -v node >/dev/null 2>&1; then
  command -v node
  exit 0
fi

for candidate in /usr/local/bin/node /usr/bin/node /opt/homebrew/bin/node; do
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    exit 0
  fi
done

nvm_dir="${NVM_DIR:-${HOME:-}/.nvm}"
if [[ -n "$nvm_dir" && -s "$nvm_dir/nvm.sh" ]]; then
  # shellcheck source=/dev/null
  source "$nvm_dir/nvm.sh"
  nvm use --silent default >/dev/null 2>&1 || true
  if command -v node >/dev/null 2>&1; then
    command -v node
    exit 0
  fi
fi

latest_nvm_node=''
for candidate in "$nvm_dir"/versions/node/*/bin/node; do
  if [[ -x "$candidate" ]]; then
    latest_nvm_node="$candidate"
  fi
done

if [[ -n "$latest_nvm_node" ]]; then
  printf '%s\n' "$latest_nvm_node"
  exit 0
fi

exit 1
