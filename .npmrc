# Use hoisted node_modules so Wrangler (esbuild) can resolve dependencies on Windows.
# Without this, pnpm's symlink layout can cause "Cannot read directory" when bundling agents.
node-linker=hoisted

# The AGNTCY Directory JS SDK (agntcy-dir) pulls its generated protobuf client
# (@buf/agntcy_dir.bufbuild_es) from the public BUF registry, not npmjs. Required
# for the slim profile's gRPC dir client in the verifier. Public, no auth.
@buf:registry=https://buf.build/gen/npm/v1/
